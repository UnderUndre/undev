# Database
DATABASE_URL=postgresql://dashboard:changeme@devops-db:5432/dashboard
POSTGRES_PASSWORD=changeme

# Auth — single API key for dashboard access
DASHBOARD_KEY=change-me-to-a-random-string

# Envelope encryption master key — base64-encoded 32 random bytes.
# Generate with: openssl rand -base64 32
# Used by server/lib/envelope-cipher.ts to encrypt SSH keys, env vars, and notification tokens at rest.
# DO NOT rotate without re-encrypting existing data.
DASHBOARD_MASTER_KEY=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Server
PORT=3000
NODE_ENV=production
